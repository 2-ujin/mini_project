# 이 파일을 복사해서 secrets.env 로 저장한 뒤, 실제 키를 채우세요.
#   (PowerShell) Copy-Item secrets.env.example secrets.env
# secrets.env 는 .gitignore / .dockerignore 로 제외되어 커밋/이미지에 들어가지 않습니다.

# Gemini API 키 (https://aistudio.google.com/apikey 에서 발급, AIza... 로 시작)
GEMINI_API_KEY=

# (선택) 하루 Gemini 호출 상한. 비워두면 기본 15.
# MAX_GEMINI_CALLS_PER_DAY=15

# PostgreSQL (Docker db 컨테이너). 비밀번호는 원하는 값으로 바꾸세요.
POSTGRES_USER=emailagent
POSTGRES_DB=emailagent
POSTGRES_PASSWORD=change-this-password
# 앱이 접속할 주소. 위 사용자/비밀번호/DB 이름과 일치해야 함. host 는 컨테이너 이름 'db'.
DATABASE_URL=postgresql://emailagent:change-this-password@db:5432/emailagent
